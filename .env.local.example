# ─────────────────────────────────────────────────────────────────────────────
# OpsAI — Variables d'environnement
# Copie ce fichier en .env.local et remplis toutes les valeurs
# JAMAIS committer .env.local dans git !
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (local dev) ─────────────────────────────────────────────────────
# Récupère ces valeurs après `supabase start`
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhb...  # affiché par `supabase start`
SUPABASE_SERVICE_ROLE_KEY=eyJhb...      # affiché par `supabase start` — NE PAS exposer au client

# ── Supabase (production) — décommenter en prod ──────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhb...
# SUPABASE_SERVICE_ROLE_KEY=eyJhb...

# ── Stripe ───────────────────────────────────────────────────────────────────
# Récupère sur https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Récupère après `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET=whsec_...

# IDs des produits Stripe (créés dans le dashboard ou via stripe CLI)
STRIPE_PRICE_STARTER_MONTHLY=price_1T7Zz5DuPqgPssJwTWnwDz4w   # 29€/mois
STRIPE_PRICE_TEAM_MONTHLY=price_1T7ZzQDuPqgPssJwtzDv7Lba      # 79€/mois

# ── IA ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...            # Pour les embeddings (text-embedding-3-small)

# ── Redis (BullMQ + Upstash) ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ── Intégrations OAuth ───────────────────────────────────────────────────────
# Gmail + Google Drive (même app OAuth Google)
# Crée sur https://console.cloud.google.com → APIs & Services → Credentials
# Callback URLs :
#   {APP_URL}/api/integrations/gmail/callback
#   {APP_URL}/api/integrations/google_drive/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Slack — https://api.slack.com/apps → OAuth & Permissions
# Callback : {APP_URL}/api/integrations/slack/callback
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Notion — https://www.notion.so/my-integrations → New integration (Public)
# Callback : {APP_URL}/api/integrations/notion/callback
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# HubSpot — https://developers.hubspot.com → App → Auth
# Callback : {APP_URL}/api/integrations/hubspot/callback
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# Microsoft (Outlook) — https://portal.azure.com → App registrations
# Callback : {APP_URL}/api/integrations/outlook/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Sécurité ─────────────────────────────────────────────────────────────────
# Clé de chiffrement des tokens OAuth (hex, 64 chars)
# Génère avec : openssl rand -hex 32
ENCRYPTION_KEY=change_me_64_hex_chars

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
